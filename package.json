{
  "name": "unity-prefab-parser",
  "version": "1.0.0",
  "description": "MCP server for parsing Unity prefab files into clean, Inspector-visible YAML format",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "unity-prefab-parser": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/*.test.ts"
  },
  "keywords": [
    "unity",
    "prefab",
    "parser",
    "mcp",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "glob": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
