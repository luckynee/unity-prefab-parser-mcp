{
  "name": "unity-prefab-parser",
  "version": "1.1.0",
  "description": "MCP server for parsing Unity prefab files into clean, Inspector-visible YAML format",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "unity-prefab-parser": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "unity",
    "prefab",
    "parser",
    "mcp",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luckynee/unity-prefab-parser-mcp.git"
  },
  "homepage": "https://github.com/luckynee/unity-prefab-parser-mcp#readme",
  "bugs": {
    "url": "https://github.com/luckynee/unity-prefab-parser-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "glob": "^13.0.6",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
